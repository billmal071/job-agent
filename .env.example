# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Flask
FLASK_SECRET_KEY=change-me-to-a-random-string
FLASK_DEBUG=false

# Database (defaults to ~/.job-agent/agent.db)
# DATABASE_URL=sqlite:///path/to/agent.db

# Email notifications (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL=

# Webhook notifications (optional)
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# Proxy (optional)
# PROXY_URL=socks5://user:pass@host:port
