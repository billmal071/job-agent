# AI Provider: anthropic, gemini, groq, openrouter, ollama
JOB_AGENT_AI_PROVIDER=gemini

# API Keys (set the one for your chosen provider)
# Google Gemini (FREE) — get key at https://aistudio.google.com/apikey
JOB_AGENT_GEMINI_API_KEY=

# Groq (FREE) — get key at https://console.groq.com
JOB_AGENT_GROQ_API_KEY=

# OpenRouter — get key at https://openrouter.ai/keys
JOB_AGENT_OPENROUTER_API_KEY=

# Anthropic Claude (PAID) — get key at https://console.anthropic.com
JOB_AGENT_ANTHROPIC_API_KEY=

# Ollama — no key needed, runs locally. Install: https://ollama.com

# Flask
JOB_AGENT_FLASK_SECRET_KEY=change-me-to-a-random-string

# Database (defaults to ~/.job-agent/agent.db)
# JOB_AGENT_DATABASE_URL=sqlite:///path/to/agent.db

# Email notifications (optional)
JOB_AGENT_SMTP_HOST=smtp.gmail.com
JOB_AGENT_SMTP_PORT=587
JOB_AGENT_SMTP_USER=
JOB_AGENT_SMTP_PASSWORD=
JOB_AGENT_NOTIFICATION_EMAIL=

# Webhook notifications (optional)
JOB_AGENT_SLACK_WEBHOOK_URL=
JOB_AGENT_DISCORD_WEBHOOK_URL=

# Proxy (optional)
# JOB_AGENT_PROXY_URL=socks5://user:pass@host:port
